<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>어떻게 바뀌었을까?</title>
    <style>
        body { margin: 0; background-color: #000; display: flex; justify-content: center; align-items: center; height: 100vh; overflow: hidden; }
        video { width: 100%; height: 100%; object-fit: contain; }
        #error-msg { color: white; font-family: sans-serif; text-align: center; display: none; }
    </style>
</head>
<body>
    <video id="myVideo" autoplay loop muted playsinline></video>
    <div id="error-msg">영상을 찾을 수 없습니다.</div>

    <script>
        // 주소창에서 숫자를 읽어오는 함수 (예: ?n=5 면 5를 가져옴)
        const urlParams = new URLSearchParams(window.location.search);
        const videoNum = urlParams.get('n');
        const videoElement = document.getElementById('myVideo');
        const errorMsg = document.getElementById('error-msg');

        if (videoNum) {
            // 영상 파일 경로 설정 (예: 1.mp4, 2.mp4 ...)
            const videoSrc = videoNum + '.mp4';
            videoElement.src = videoSrc;
            
            // 영상이 없을 경우 에러 메시지 표시
            videoElement.onerror = function() {
                videoElement.style.display = 'none';
                errorMsg.style.display = 'block';
            };
        } else {
            errorMsg.innerText = "번호가 지정되지 않았습니다.";
            errorMsg.style.display = 'block';
        }
    </script>
</body>
</html>
